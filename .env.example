# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Customer ID Configuration
# For TEST developer token: use your Test Account Customer ID
# For APPROVED developer token: use your production Customer ID
GOOGLE_ADS_CUSTOMER_ID=1234567890

# Optional: Use this when accessing through a Manager Account
GOOGLE_ADS_LOGIN_CUSTOMER_ID=9876543210

# Google OAuth (for Google Ads API)
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token

# Google OAuth (for Drive & Sheets)
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Google Drive
GOOGLE_DRIVE_EXPORT_FOLDER_ID=your-export-folder-id
GOOGLE_DRIVE_INPUT_FOLDER_ID=your-input-folder-id

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Runtime Configuration
# Batch size: number of keywords per API request
# Google Ads API limit: maximum 20 keywords per request (generateKeywordIdeas endpoint)
# Recommended values: 1-20
# - 10: Conservative (10,000 words/day with default budget)
# - 20: Maximum API limit (20,000 words/day with default budget)
BATCH_SIZE=10
MAX_RETRY_COUNT=3
FREE_TIER_ADS_BUDGET=1000
FREE_TIER_DRIVE_BUDGET=100
FREE_TIER_SHEETS_BUDGET=50

# Google Ads API Configuration
GOOGLE_ADS_GEO_TARGET_CONSTANTS=geoTargetConstants/2840
GOOGLE_ADS_LANGUAGE=languageConstants/1000
GOOGLE_ADS_KEYWORD_PLAN_NETWORK=GOOGLE_SEARCH

# Testing Mode (set to 'true' to use mock API instead of real Google Ads API)
# This allows testing the entire pipeline without waiting for API approval
USE_MOCK_API=false



