# ─── Google Ads ───────────────────────────────────────────────────────────────
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LANGUAGE_CONSTANT=languageConstants/1000
GOOGLE_ADS_GEO_TARGET_CONSTANT=geoTargetConstants/2840

# ─── Google Drive / Sheets ────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ─── Google Service Account (optional; used instead of OAuth if both are set) ─
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ─── Cloudflare (required for scripts that access R2 and D1 from Node.js) ─────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
R2_BUCKET_NAME=keyword-metrics-results

# ─── General ─────────────────────────────────────────────────────────────────
ENVIRONMENT=staging
